{
  "expo": {
    "name": "Happie",
    "slug": "happie-dinner",
    "scheme": "happie",
    "version": "1.5.1",
    "orientation": "portrait",
    "icon": "./assets/icon-happie.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FEFEFE"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon-happie.png",
      "bundleIdentifier": "com.willemgrasso.happie",
      "buildNumber": "1.2.0",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "webcredentials:studentenhappie.nl",
        "applinks:studentenhappie.nl"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Happie needs camera access to take recipe photos",
        "NSPhotoLibraryUsageDescription": "Happie needs photo library access to select recipe photos",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.willemgrasso.happie",
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Happie needs access to your photos to add recipe images",
          "cameraPermission": "Happie needs access to your camera to take recipe photos"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#8B7355",
          "sounds": []
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "ef1bab23-7ed4-42f7-bcea-56df83d45919"
      }
    },
    "owner": "willem_grasso"
  }
}
